    <worksheet name='chart_top_growth'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#0f172a' fontsize='12'>Top 5 Boroughs by Price Growth</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#6b7280' fontsize='8'>YoY median sale price change, 2024</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='v_borough_yoy_growth' name='federated.0hwet341hngp9g18pceyr166ymu0' />
            <datasource caption='v_market_health_summary' name='federated.0l6yltp0olc7ng1967t6q0a6t9uu' />
            <datasource caption='v_property_type_roi_by_borough' name='federated.1a50it61mfnepk144r1as0g3xqpq' />
          </datasources>
          <datasource-dependencies datasource='federated.0hwet341hngp9g18pceyr166ymu0'>
            <column caption='Borough' datatype='string' name='[BOROUGH]' role='dimension' type='nominal' />
            <column caption='Is Top Borough' datatype='string' name='[Calculation_0716888913702912]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF RANK(AVG([YOY_MEDIAN_CHANGE_PCT]), &apos;desc&apos;) = 1 &#13;&#10;   THEN &apos;Top&apos; &#13;&#10;   ELSE &apos;Other&apos; &#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Year' datatype='integer' datatype-customized='true' name='[YEAR]' role='dimension' type='quantitative' />
            <column caption='Yoy Median Change Pct' datatype='real' name='[YOY_MEDIAN_CHANGE_PCT]' role='measure' type='quantitative' />
            <column-instance column='[YOY_MEDIAN_CHANGE_PCT]' derivation='Avg' name='[avg:YOY_MEDIAN_CHANGE_PCT:qk]' pivot='key' type='quantitative' />
            <column-instance column='[BOROUGH]' derivation='None' name='[none:BOROUGH:nk]' pivot='key' type='nominal' />
            <column-instance column='[YEAR]' derivation='None' name='[none:YEAR:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0716888913702912]' derivation='User' name='[usr:Calculation_0716888913702912:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Columns' />
            </column-instance>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0l6yltp0olc7ng1967t6q0a6t9uu'>
            <column caption='Year' datatype='integer' name='[YEAR]' role='dimension' type='quantitative' />
            <column-instance column='[YEAR]' derivation='None' name='[none:YEAR:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1a50it61mfnepk144r1as0g3xqpq'>
            <column caption='Borough' datatype='string' name='[BOROUGH]' role='dimension' type='nominal' />
            <column-instance column='[BOROUGH]' derivation='None' name='[none:BOROUGH:nk]' pivot='key' type='nominal' />
