      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0hwet341hngp9g18pceyr166ymu0].[avg:AVG_PRICE:qk]&quot;' value='Average Price' />
          <alias key='&quot;[federated.0hwet341hngp9g18pceyr166ymu0].[avg:MEDIAN_PRICE:qk]&quot;' value='Median Price' />
          <alias key='&quot;[federated.0hwet341hngp9g18pceyr166ymu0].[avg:YOY_MEDIAN_CHANGE_PCT:qk]&quot;' value='YoY Median Change' />
