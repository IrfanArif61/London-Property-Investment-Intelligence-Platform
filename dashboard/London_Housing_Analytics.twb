      </column>
      <column caption='Avg Price' datatype='integer' name='[AVG_PRICE]' role='measure' type='quantitative' />
      <column caption='Borough' datatype='string' name='[BOROUGH]' role='dimension' type='nominal' />
      <column caption='Is Top Borough' datatype='string' name='[Calculation_0716888913702912]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(AVG([YOY_MEDIAN_CHANGE_PCT]), &apos;desc&apos;) = 1 &#13;&#10;   THEN &apos;Top&apos; &#13;&#10;   ELSE &apos;Other&apos; &#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Central or Outer' datatype='string' name='[Calculation_0716889265336323]' role='dimension' type='nominal'>
